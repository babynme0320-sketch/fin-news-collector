<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0f172a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>금융 데일리 {{ date }}</title>
  <style>
    :root {
      --bg: #f1f5f9;
      --surface: #ffffff;
      --surface2: #f8fafc;
      --line: #e2e8f0;
      --text: #0f172a;
      --text2: #334155;
      --muted: #64748b;
      --up: #16a34a;
      --up-bg: #f0fdf4;
      --down: #dc2626;
      --down-bg: #fef2f2;
      --flat: #94a3b8;
      --primary: #2563eb;
      --primary-light: #eff6ff;
      --nav-h: 48px;
      --safe-top: env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0f172a;
        --surface: #1e293b;
        --surface2: #0f172a;
        --line: #334155;
        --text: #f1f5f9;
        --text2: #cbd5e1;
        --muted: #94a3b8;
        --up-bg: #052e16;
        --down-bg: #450a0a;
        --primary-light: #1e3a5f;
      }
    }

    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo",
                   "Noto Sans KR", "Malgun Gothic", sans-serif;
      font-size: 15px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      padding-bottom: calc(16px + var(--safe-bottom));
    }

    /* ── 상단 헤더 ──────────────────────────── */
    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--line);
      padding: calc(12px + var(--safe-top)) 16px 12px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .topbar-inner {
      display: flex;
      align-items: baseline;
      gap: 10px;
    }
    .topbar h1 {
      margin: 0;
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.3px;
    }
    .topbar .date-label {
      font-size: 12px;
      color: var(--muted);
      white-space: nowrap;
    }

    /* ── 섹션 탭 네비 ──────────────────────── */
    .nav-tabs {
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      gap: 4px;
      padding: 8px 12px;
      background: var(--surface);
      border-bottom: 1px solid var(--line);
      position: sticky;
      top: calc(var(--safe-top) + 48px);
      z-index: 99;
    }
    .nav-tabs::-webkit-scrollbar { display: none; }
    .nav-tab {
      flex-shrink: 0;
      padding: 6px 14px;
      border-radius: 20px;
      border: 1px solid var(--line);
      background: var(--bg);
      color: var(--text2);
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .nav-tab:active {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary);
    }

    /* ── 메인 레이아웃 ─────────────────────── */
    main { padding: 12px 12px 8px; }

    /* ── 시장 지표 그리드 ──────────────────── */
    .market-section {
      background: var(--surface);
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 12px;
    }
    .section-head {
      padding: 14px 16px 10px;
      font-size: 14px;
      font-weight: 700;
      color: var(--muted);
      letter-spacing: 0.3px;
      text-transform: uppercase;
      border-bottom: 1px solid var(--line);
    }
    .indices {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }
    .card {
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      border-right: 1px solid var(--line);
      cursor: pointer;
      transition: background 0.15s;
      position: relative;
    }
    .card:active { background: var(--surface2); }
    /* 짝수 열은 right border 없음 */
    .card:nth-child(2n) { border-right: none; }
    /* 마지막 행 border-bottom 제거 */
    .card:nth-last-child(-n+2) { border-bottom: none; }
    /* 홀수 마지막 하나 */
    .card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
      border-right: none;
    }
    .card.up  { background: var(--up-bg); }
    .card.down { background: var(--down-bg); }
    .card.na  { opacity: 0.6; }

    .card-label { font-size: 11px; color: var(--muted); font-weight: 600; margin-bottom: 4px; }
    .card-price { font-size: 18px; font-weight: 700; letter-spacing: -0.5px; line-height: 1.2; }
    .card-change { font-size: 13px; font-weight: 600; margin-top: 3px; }
    .card-change.up   { color: var(--up); }
    .card-change.down { color: var(--down); }
    .card-change.flat { color: var(--flat); }
    .chart-hint {
      position: absolute;
      top: 10px; right: 10px;
      font-size: 14px;
      opacity: 0.3;
    }

    /* ── 속보 섹션 ─────────────────────────── */
    .sokbo-section .section-head {
      background: #dc2626;
      color: #fff;
      border-bottom: none;
    }
    .sokbo-section .section-head .item-count {
      background: rgba(255,255,255,0.2);
      color: #fff;
    }
    .sokbo-badge {
      display: inline-flex;
      align-items: center;
      padding: 1px 7px;
      border-radius: 999px;
      background: #dc2626;
      color: #fff;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.3px;
      flex-shrink: 0;
    }
    .sokbo-section .news-item {
      border-left: 3px solid #dc2626;
    }
    .sokbo-section .item-link {
      font-weight: 700;
    }

    /* ── 뉴스 섹션 ─────────────────────────── */
    .news-section {
      background: var(--surface);
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 12px;
      scroll-margin-top: calc(var(--safe-top) + var(--nav-h) + 60px);
    }
    .news-section .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .item-count {
      font-size: 12px;
      font-weight: 500;
      color: var(--muted);
      background: var(--bg);
      padding: 2px 8px;
      border-radius: 10px;
      text-transform: none;
    }

    .news-item {
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      transition: background 0.12s;
    }
    .news-item:last-child { border-bottom: none; }
    .news-item:active { background: var(--surface2); }

    .item-link {
      display: block;
      color: var(--text);
      text-decoration: none;
      font-size: 15px;
      font-weight: 600;
      line-height: 1.45;
    }
    .item-link:active { color: var(--primary); }

    .item-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 4px;
    }
    .item-date { font-size: 12px; color: var(--muted); }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      padding: 1px 7px;
      border-radius: 999px;
      background: var(--primary-light);
      color: var(--primary);
      font-size: 11px;
      font-weight: 700;
    }
    .item-lede {
      margin-top: 6px;
      color: var(--text2);
      font-size: 13.5px;
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .error-msg {
      padding: 14px 16px;
      color: #b91c1c;
      font-size: 14px;
      background: var(--down-bg);
    }
    .empty-msg {
      padding: 14px 16px;
      color: var(--muted);
      font-size: 14px;
    }

    /* ── 차트 모달 (모바일 풀스크린) ─────────── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(4px);
      z-index: 200;
      display: flex;
      align-items: flex-end;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }
    .modal-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }
    .modal-sheet {
      background: var(--surface);
      border-radius: 20px 20px 0 0;
      width: 100%;
      max-height: 88vh;
      padding: 0 0 calc(16px + var(--safe-bottom));
      transform: translateY(100%);
      transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .modal-overlay.active .modal-sheet {
      transform: translateY(0);
    }
    .sheet-handle {
      width: 36px; height: 4px;
      background: var(--line);
      border-radius: 2px;
      margin: 10px auto 0;
      flex-shrink: 0;
    }
    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 16px 10px;
      border-bottom: 1px solid var(--line);
      flex-shrink: 0;
    }
    .modal-header h2 { font-size: 16px; font-weight: 700; margin: 0; }
    .close-btn {
      background: var(--bg);
      border: none;
      width: 32px; height: 32px;
      border-radius: 50%;
      font-size: 20px;
      cursor: pointer;
      color: var(--muted);
      display: flex; align-items: center; justify-content: center;
      padding: 0;
    }
    .chart-filters {
      display: flex;
      gap: 6px;
      padding: 10px 16px;
      border-bottom: 1px solid var(--line);
      flex-shrink: 0;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .chart-filters::-webkit-scrollbar { display: none; }
    .filter-btn {
      flex-shrink: 0;
      background: var(--bg);
      border: 1px solid var(--line);
      color: var(--text2);
      padding: 7px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      min-height: 36px;
    }
    .filter-btn.active {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary);
    }
    .chart-wrap {
      flex: 1;
      overflow: hidden;
      padding: 4px 8px 0;
    }
    #chart-canvas { width: 100%; height: 100%; min-height: 260px; }

    /* ── 태블릿 / 데스크탑 ─────────────────── */
    @media (min-width: 600px) {
      main { padding: 16px; max-width: 720px; margin: 0 auto; }
      .indices { grid-template-columns: repeat(3, 1fr); }
      .modal-overlay { align-items: center; }
      .modal-sheet {
        border-radius: 20px;
        max-width: 680px;
        max-height: 80vh;
        margin: auto;
      }
      .sheet-handle { display: none; }
    }
    @media (min-width: 900px) {
      main { max-width: 900px; }
      .indices { grid-template-columns: repeat(4, 1fr); }
    }
  </style>
</head>
<body>

  <!-- 상단 헤더 -->
  <div class="topbar">
    <div class="topbar-inner">
      <h1>금융 데일리</h1>
      <span class="date-label">{{ date }}</span>
    </div>
  </div>

  <!-- 섹션 탭 네비 -->
  <nav class="nav-tabs">
    <a class="nav-tab" href="#market">📈 증시</a>
    {% for section in sections %}
    <a class="nav-tab" href="#sec-{{ loop.index }}">{% if section.name == "속보" %}🚨 속보{% else %}{{ section.name }}{% endif %}</a>
    {% endfor %}
  </nav>

  <main>

    <!-- 시장 지표 -->
    <div class="market-section" id="market">
      <div class="section-head">📈 주요 증시 & 거시 지표</div>
      {% if market_error %}
      <div class="error-msg">⚠️ 증시 데이터 수집 실패: {{ market_error }}</div>
      {% elif not indices %}
      <div class="empty-msg">증시 데이터 없음</div>
      {% else %}
      <div class="indices">
        {% for idx in indices %}
          {% if not idx.available %}
          <div class="card na" data-name="{{ idx.name }}">
            <div class="chart-hint">📊</div>
            <div class="card-label">{{ idx.name }}</div>
            <div class="card-price">—</div>
            <div class="card-change flat">데이터 없음</div>
          </div>
          {% else %}
          {% set dir = "up" if idx.change_pct > 0 else ("down" if idx.change_pct < 0 else "flat") %}
          <div class="card {{ dir }}" data-name="{{ idx.name }}">
            <div class="chart-hint">📊</div>
            <div class="card-label">{{ idx.name }}</div>
            <div class="card-price">{{ "%.2f"|format(idx.price) }}</div>
            <div class="card-change {{ dir }}">{{ "+" if idx.change_pct > 0 else "" }}{{ "%.2f"|format(idx.change_pct) }}%</div>
          </div>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <!-- 뉴스 섹션들 -->
    {% for section in sections %}
    {% set is_sokbo = section.name == "속보" %}
    <div class="news-section{% if is_sokbo %} sokbo-section{% endif %}" id="sec-{{ loop.index }}">
      <div class="section-head">
        {% if is_sokbo %}🚨 속보{% else %}{{ section.name }}{% endif %}
        {% if section.entries %}<span class="item-count">{{ section.entries | length }}건</span>{% endif %}
      </div>
      {% if section.error %}
      <div class="error-msg">⚠️ 수집 실패: {{ section.error }}</div>
      {% elif not section.entries %}
      <div class="empty-msg">수집된 항목 없음</div>
      {% else %}
        {% for item in section.entries %}
        <div class="news-item">
          <a class="item-link" href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.title }}</a>
          <div class="item-meta">
            {% if item.date %}<span class="item-date">{{ item.date }}</span>{% endif %}
            {% if is_sokbo %}<span class="sokbo-badge">속보</span>{% endif %}
            {% if item.is_pdf %}<span class="badge">PDF</span>{% endif %}
          </div>
          {% if item.lede %}<p class="item-lede">{{ item.lede }}</p>{% endif %}
        </div>
        {% endfor %}
      {% endif %}
    </div>
    {% endfor %}

  </main>

  <!-- 차트 모달 (바텀 시트) -->
  <div id="chart-modal" class="modal-overlay">
    <div class="modal-sheet">
      <div class="sheet-handle"></div>
      <div class="modal-header">
        <h2 id="modal-title">지표 추이</h2>
        <button id="close-modal" class="close-btn">&times;</button>
      </div>
      <div class="chart-filters">
        <button class="filter-btn active" data-period="all">전체</button>
        <button class="filter-btn" data-period="120">10년</button>
        <button class="filter-btn" data-period="60">5년</button>
        <button class="filter-btn" data-period="12">1년</button>
      </div>
      <div class="chart-wrap">
        <div id="chart-canvas"></div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  <script>
    const historyData = {{ history_data | tojson }};
    let chartInstance = null;
    let currentIndexName = "";

    const modal = document.getElementById('chart-modal');
    const modalTitle = document.getElementById('modal-title');
    const closeBtn = document.getElementById('close-modal');
    const filterBtns = document.querySelectorAll('.filter-btn');

    document.querySelectorAll('.card').forEach(card => {
      card.addEventListener('click', () => {
        const name = card.dataset.name;
        if (historyData && historyData[name]) openModal(name);
      });
    });

    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderChart(currentIndexName, btn.dataset.period);
      });
    });

    function openModal(name) {
      currentIndexName = name;
      modalTitle.textContent = name + ' 장기 추이';
      modal.classList.add('active');
      filterBtns.forEach(b => b.classList.remove('active'));
      document.querySelector('.filter-btn[data-period="all"]').classList.add('active');
      renderChart(name, 'all');
    }

    function closeModal() {
      modal.classList.remove('active');
      if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
    }

    function renderChart(name, period) {
      let pts = historyData[name] || [];
      if (period !== 'all') pts = pts.slice(-parseInt(period, 10));

      const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const textColor = isDark ? '#94a3b8' : '#64748b';
      const gridColor = isDark ? '#334155' : '#f1f5f9';

      const opts = {
        series: [{ name, data: pts.map(d => d.value) }],
        chart: {
          type: 'line',
          height: document.getElementById('chart-canvas').clientHeight || 260,
          background: 'transparent',
          toolbar: { show: false },
          animations: { enabled: true, speed: 400 }
        },
        theme: { mode: isDark ? 'dark' : 'light' },
        stroke: { curve: 'smooth', width: 2.5, colors: ['#2563eb'] },
        markers: { size: 0, hover: { size: 5 } },
        grid: { borderColor: gridColor },
        xaxis: {
          categories: pts.map(d => d.date),
          labels: {
            style: { colors: textColor, fontSize: '10px' },
            rotate: -30,
            hideOverlappingLabels: true
          },
          tickAmount: window.innerWidth < 500 ? 6 : 12
        },
        yaxis: {
          labels: {
            formatter: v => v.toLocaleString(),
            style: { colors: textColor, fontSize: '10px' }
          }
        },
        tooltip: {
          y: { formatter: v => v.toLocaleString() }
        },
        colors: ['#2563eb']
      };

      if (chartInstance) { chartInstance.destroy(); }
      chartInstance = new ApexCharts(document.querySelector('#chart-canvas'), opts);
      chartInstance.render();
    }
  </script>
</body>
</html>
